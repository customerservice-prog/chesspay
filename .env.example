# ─────────────────────────────────────────────
# Checkmate.GG — Environment Variables Template
# Copy this file to .env.local and fill in values.
# NEVER commit .env.local to version control.
# ─────────────────────────────────────────────

# ── Database ──────────────────────────────────
# Local dev: postgresql://postgres:password@localhost:5432/checkmategg
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/checkmategg"

# ── Auth / JWT ────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_ACCESS_SECRET="CHANGE_ME_access_secret_min_32_chars"
JWT_REFRESH_SECRET="CHANGE_ME_refresh_secret_min_32_chars"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ── App ───────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_SOCKET_URL="http://localhost:3000"
NODE_ENV="development"
PORT="3000"

# ── Stripe (scaffolded — not active in Phase 1) ──
STRIPE_SECRET_KEY="sk_test_REPLACE_ME"
STRIPE_WEBHOOK_SECRET="whsec_REPLACE_ME"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_REPLACE_ME"

# ── Logging ───────────────────────────────────
LOG_LEVEL="debug"   # debug | info | warn | error

# ── Platform Config ───────────────────────────
PLATFORM_ACCOUNT_ID="00000000-0000-0000-0000-000000000001"
RAKE_PERCENT="7.50"
PAYOUT_HOLD_MINUTES="15"
HIGH_STAKES_THRESHOLD_USD="25.00"
RECONNECT_WINDOW_SECONDS="60"
