# ─────────────────────────────────────────────
# Checkmate.GG — Environment Variables Template
# Copy this file to .env.local and fill in values.
# NEVER commit .env.local to version control.
# ─────────────────────────────────────────────

# ── Database ──────────────────────────────────
# Easiest local dev (no Docker): embedded Postgres via PGlite
USE_PGLITE="true"
# PGlite stores data under %TEMP%/chesspay-pglite-data by default (avoids OneDrive/sync issues).
# Optional overrides: PGLITE_DATA_PATH=".pglite/data" | "memory://"

# When USE_PGLITE is unset/false, set DATABASE_URL instead:
# Docker (see docker-compose.yml, port 5433):
#   postgresql://postgres:postgres@127.0.0.1:5433/checkmategg
# Native Postgres:
#   postgresql://USER:PASSWORD@127.0.0.1:5432/checkmategg
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5433/checkmategg"

# ── Auth / JWT ────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_ACCESS_SECRET="CHANGE_ME_access_secret_min_32_chars"
JWT_REFRESH_SECRET="CHANGE_ME_refresh_secret_min_32_chars"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ── App ───────────────────────────────────────
# Port 3002 by default (leave 3000/3001 for other tools). Keep URLs aligned with PORT.
NEXT_PUBLIC_APP_URL="http://localhost:3002"
NEXT_PUBLIC_SOCKET_URL="http://localhost:3002"
NODE_ENV="development"
PORT="3002"

# ── Stripe (scaffolded — not active in Phase 1) ──
STRIPE_SECRET_KEY="sk_test_REPLACE_ME"
STRIPE_WEBHOOK_SECRET="whsec_REPLACE_ME"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_REPLACE_ME"

# ── Logging ───────────────────────────────────
LOG_LEVEL="debug"   # debug | info | warn | error

# ── Platform Config ───────────────────────────
PLATFORM_ACCOUNT_ID="00000000-0000-0000-0000-000000000001"
RAKE_PERCENT="7.50"
# Client lobby / game UI (keep in sync with RAKE_PERCENT)
NEXT_PUBLIC_RAKE_PERCENT="7.5"
PAYOUT_HOLD_MINUTES="15"
HIGH_STAKES_THRESHOLD_USD="25.00"
RECONNECT_WINDOW_SECONDS="60"
